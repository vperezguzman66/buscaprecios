# MercadoLibre API credentials
# Regístrate gratis en https://developers.mercadolibre.com/
# y crea una aplicación para obtener estas credenciales.
#
# Cómo obtenerlas:
#   1. Ve a https://developers.mercadolibre.com/
#   2. Inicia sesión con tu cuenta de MercadoLibre
#   3. Crea una nueva aplicación (puedes poner cualquier nombre/URL)
#   4. Copia el Client ID y el Secret Key
#
# Una vez configurado, MercadoLibre aparecerá habilitado en la interfaz.

ML_CLIENT_ID=tu_client_id_aqui
ML_CLIENT_SECRET=tu_client_secret_aqui
